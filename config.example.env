# Copy to .env and fill in your values.

# Default TTS provider: sarvam or elevenlabs
TTS_PROVIDER=sarvam

# Default script format: monologue or conversation
DEFAULT_FORMAT=monologue

# ── ElevenLabs ───────────────────────────────────────────────────────────────
# API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Voice IDs from https://elevenlabs.io/app/voice-library (pick two distinct voices)
# Host A = curious lead (sets up ideas). Host B = reactive co-host (pushes back).
HOST_A_VOICE_ID=
HOST_B_VOICE_ID=

# Optional: model override
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Sarvam ───────────────────────────────────────────────────────────────────
# API key from https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Speaker names. Options: anushka, abhilash, arya, manisha, vidya, karun, hitesh
SARVAM_HOST_A_SPEAKER=anushka
SARVAM_HOST_B_SPEAKER=abhilash
SARVAM_NARRATOR_SPEAKER=arya

SARVAM_MODEL=bulbul:v2
SARVAM_LANGUAGE=en-IN

# ── Podcast feed metadata ────────────────────────────────────────────────────
FEED_OWNER_NAME=Your Name
FEED_OWNER_EMAIL=you@example.com
# FEED_TITLE=My Book Podcast          # optional, defaults to "<FEED_OWNER_NAME>'s Book Podcast"
# FEED_DESCRIPTION=...                # optional

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Create a bucket at https://dash.cloudflare.com, enable public access,
# generate an API token with Object Read & Write.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=podcast
R2_PUBLIC_BASE=https://pub-<random>.r2.dev

# ── LLM for script generation (standalone run.py only) ───────────────────────
# When running via Claude Code, Claude generates the script itself — these are ignored.
# When running via run.py directly, one of these must be set.
LLM_PROVIDER=anthropic          # anthropic | openai | ollama
LLM_MODEL=                      # leave blank for provider default (claude-opus-4-7 / gpt-4o / llama3.1:70b)

ANTHROPIC_API_KEY=              # https://console.anthropic.com
# OPENAI_API_KEY=               # https://platform.openai.com
# OLLAMA_URL=http://localhost:11434   # local Ollama instance

# ── Local paths ──────────────────────────────────────────────────────────────
# Where intermediate artifacts (book.txt, script.md, chunks.json, episode.mp3) live.
WORK_DIR=~/book-podcasts/out
